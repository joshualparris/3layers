{
  "framework": "vite",
  "installCommand": "cd Epic-Quest-Saga && npx pnpm@10.29.3 install --frozen-lockfile",
  "buildCommand": "cd Epic-Quest-Saga && npx pnpm@10.29.3 --filter @workspace/continuity-app build",
  "outputDirectory": "Epic-Quest-Saga/artifacts/continuity-app/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
